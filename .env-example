# Core runtime
INSPECTOR_OUTPUT_DIR=output
INSPECTOR_DEFAULT_ITERATIONS=2
INSPECTOR_AGENT_MODE=auto
INSPECTOR_ALLOW_MOCK_FALLBACK=true
# When true, the arbitrator first reads the generated plan and selects only
# relevant reviewers from the configured reviewer catalog.
INSPECTOR_DYNAMIC_REVIEWER_SELECTION=false
# Optional override. If unset, --idea uses inspector.new-idea.config.json when present,
# --plan-file uses inspector.existing-plan.config.json when present,
# --research uses inspector.research.config.json when present,
# and --problem uses inspector.problem.config.json when present.
INSPECTOR_CONFIG_FILE=
INSPECTOR_MOCK_REVIEWERS=Software Architect,Security Analyst,Delivery Manager,UI/UX Analyst,DevOps Engineer,Full Stack Engineer,Team Lead
# Optional env overrides for config-file agent setup.
INSPECTOR_REVIEWERS=
INSPECTOR_ARBITRATOR=
# Optional JSON spec for an agent that proposes extra --research discovery questions.
# Example: {"active":true,"provider":"openai","model_env":"OPENAI_DEEP_MODEL","api_key_env":"OPENAI_API_KEY"}
INSPECTOR_RESEARCH_QUESTION_PLANNER=
INSPECTOR_HTTP_TIMEOUT_SECONDS=30
INSPECTOR_HTTP_MAX_RETRIES=2
INSPECTOR_HTTP_BACKOFF_SECONDS=1
# Optional Obsidian context. Point this at the single markdown note that represents
# the idea; linked notes are resolved from the same vault/folder tree.
INSPECTOR_OBSIDIAN_IDEA_FILE=
INSPECTOR_OBSIDIAN_MAX_DEPTH=1
INSPECTOR_OBSIDIAN_MAX_NOTES=12

# Agent provider keys (for future real integrations)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# Provider-level model defaults. Workflow configs inherit these when reviewer/arbitrator
# entries omit "model"; set an agent-level "model" only for intentional exceptions.
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_MODEL=claude-haiku-4-5
GROK_MODEL=grok-3-mini

# Optional named model aliases for individual agents via "model_env" in JSON configs.
# Example: {"provider": "openai", "model_env": "OPENAI_DEEP_MODEL"}
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_DEEP_MODEL=gpt-5.4
